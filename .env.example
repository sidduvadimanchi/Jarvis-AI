# Jarvis AI — Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ═══════════════════════════════════════════════════
#  REQUIRED — The assistant will not start without these
# ═══════════════════════════════════════════════════

# Get free key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Your name (shown in chat)
Username=Your Name

# Assistant name
Assistantname=Jarvis

# ═══════════════════════════════════════════════════
#  OPTIONAL — Enables enhanced intent classification
# ═══════════════════════════════════════════════════

# Get free key from: https://dashboard.cohere.com/api-keys
CohereAPIKey=your_cohere_key_here

# ═══════════════════════════════════════════════════
#  VOICE SETTINGS
# ═══════════════════════════════════════════════════

# Microsoft Neural Voices: en-US-AriaNeural, en-US-JennyNeural, en-GB-SoniaNeural
AssistantVoice=en-US-AriaNeural
VoiceRate=+0%
VoicePitch=+0Hz
VoiceVolume=1.0
InputLanguage=en-US

# ═══════════════════════════════════════════════════
#  REAL-TIME DATA
# ═══════════════════════════════════════════════════

# Your city for weather (default: Bhopal)
City=Bhopal

# Optional: https://openweathermap.org/api
OpenWeatherKey=

# Optional: https://newsapi.org
NewsAPIKey=

# ═══════════════════════════════════════════════════
#  EMAIL — Gmail OAuth2 (setup guide in GMAIL_SETUP_GUIDE.txt)
# ═══════════════════════════════════════════════════

GmailUser=your@gmail.com
GmailDisplayName=Your Name
GmailSignature=B.Tech CSE | Your University

# Add contacts for easy email (Contact_name=email@domain.com)
# Contact_professor=prof@college.edu
# Contact_friend=friend@gmail.com

# ═══════════════════════════════════════════════════
#  AI MODEL SETTINGS
# ═══════════════════════════════════════════════════

# Groq model to use (free tier)
GroqModel=llama-3.1-8b-instant
